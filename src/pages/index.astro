---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
	<section class="relative bg-brand-dark text-brand-light overflow-hidden">
		<div class="relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 py-28 lg:py-36 flex flex-col items-center text-center">
			<h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tighter mb-8 max-w-4xl leading-tight">
				IMT: Where <span class="text-brand-gold">Theory</span> and <span class="text-brand-gold">Application</span> Converge
			</h1>
			<p class="text-xl md:text-2xl text-gray-300 max-w-3xl mb-12 leading-relaxed font-light">
				Welcome to the <span class="text-brand-gold">Integrated Mathematics Tournament</span>, an annual online mathematics competition aimed for middle and high schoolers introducing people to a wider range of mathematical topics.
			</p>
			<div class="flex flex-col sm:flex-row gap-6">
				<a href="/imt-website/about" class="bg-brand-gold text-brand-dark font-bold py-4 px-10 rounded-full shadow-lg hover:opacity-90 hover:scale-105 transition transform duration-200 text-lg">
					Learn More
				</a>
				<a href="/imt-website/team" class="bg-transparent border-2 border-brand-gold text-brand-gold font-bold py-4 px-10 rounded-full hover:bg-brand-gold hover:text-brand-dark transition duration-200 text-lg">
				</a>
			</div>
		</div>
	</section>

	<section class="py-24 bg-brand-light">
		<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
			<div class="text-center mb-20 max-w-3xl mx-auto">
				<h2 class="text-4xl font-extrabold text-brand-dark mb-6 tracking-tight">Mathematics Reimagined</h2>
				<p class="text-xl text-gray-700 leading-relaxed font-light">We aim to deviate from quick calculations and memorization, and introduce individuals to applied mathematics and deeper thinking skills.</p>
				<div class="mt-6 w-32 h-1 bg-brand-green mx-auto rounded-full"></div>
			</div>
			<div class="grid md:grid-cols-3 gap-12 text-center">
				<div class="p-8 bg-white rounded-3xl shadow-card group hover:shadow-card-hover hover:border-brand-gold hover:scale-[1.02] transition duration-300 border border-gray-100">
					<div class="w-20 h-20 bg-brand-green text-brand-light rounded-full flex items-center justify-center mx-auto mb-8 text-3xl font-extrabold group-hover:scale-110 transition transform duration-300">1</div>
					<h3 class="text-2xl font-semibold mb-5 text-brand-dark group-hover:text-brand-green_dark transition">Bridge the Gap</h3>
					<p class="text-gray-700 leading-relaxed text-lg font-light">IMT integrates competition math concepts with real-world data and fields of applied mathematics.</p>
				</div>
				<div class="p-8 bg-white rounded-3xl shadow-card group hover:shadow-card-hover hover:border-brand-gold hover:scale-[1.02] transition duration-300 border border-gray-100">
					<div class="w-20 h-20 bg-brand-green text-brand-light rounded-full flex items-center justify-center mx-auto mb-8 text-3xl font-extrabold group-hover:scale-110 transition transform duration-300">2</div>
					<h3 class="text-2xl font-semibold mb-5 text-brand-dark group-hover:text-brand-green_dark transition">Foster Collaboration</h3>
					<p class="text-gray-700 leading-relaxed text-lg font-light">IMT encourages teamwork, collaboration, brainstorming, and diverse perspectives.</p>
				</div>
				<div class="p-8 bg-white rounded-3xl shadow-card group hover:shadow-card-hover hover:border-brand-gold hover:scale-[1.02] transition duration-300 border border-gray-100">
					<div class="w-20 h-20 bg-brand-green text-brand-light rounded-full flex items-center justify-center mx-auto mb-8 text-3xl font-extrabold group-hover:scale-110 transition transform duration-300">3</div>
					<h3 class="text-2xl font-semibold mb-5 text-brand-dark group-hover:text-brand-green_dark transition">Encourage Deep Thinking</h3>
					<p class="text-gray-700 leading-relaxed text-lg font-light">IMT introduces students to solve open-ended problems that demand analytical depth and critical reasoning, not just speed and calculations.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>