---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Practice Materials">
	<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 py-20 text-center">
		
		<div class="text-center max-w-3xl mx-auto mb-20 border-b-2 border-slate-200 pb-12">
			<h1 class="text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">Example Problem Sets</h1>
			<p class="text-xl text-slate-600 leading-relaxed font-light">This page consists of past competition sets and also example problems to help competitiors get a feel for the style of IMT.</p>
		</div>

		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 text-left">
			
			<div class="bg-brand-light border-2 border-brand-gold rounded-2xl p-8 shadow-inner hover:shadow-card-hover hover:scale-[1.03] transition duration-300 group flex flex-col h-full">
				<div class="bg-brand-gold text-brand-dark text-xs font-bold uppercase px-4 py-1.5 rounded-full inline-block mb-5 shadow-sm self-start">Integrated Round</div>
				<h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-brand-gold transition">Sample Integrated Round on Computational Biology</h3>
				<p class="text-slate-700 text-base mb-8 line-clamp-3 font-light">An example integrated round consisting of four sections and example problems.</p>
				<button class="w-full bg-brand-dark text-brand-light font-semibold py-3 rounded-lg hover:opacity-90 transition group-hover:scale-105 transform mt-auto">Coming Soon</button>
			</div>

			<div class="bg-white border-2 border-slate-100 rounded-2xl p-8 shadow-card hover:shadow-card-hover hover:scale-[1.03] transition duration-300 group hover:border-slate-300 flex flex-col h-full">
				<div class="bg-slate-200 text-slate-800 text-xs font-bold uppercase px-4 py-1.5 rounded-full inline-block mb-5 shadow-sm self-start">Team Round</div>
				<h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-brand-dark transition">Sample Team Round</h3>
				<p class="text-slate-700 text-base mb-8 line-clamp-3 font-light">A 40-minute collaborative test consisting of 10 questions of increasing difficulty.</p>
				<button class="w-full bg-slate-900 text-white font-semibold py-3 rounded-lg hover:bg-slate-700 transition group-hover:scale-105 transform mt-auto">Coming Soon</button>
			</div>

			<div class="bg-white border-2 border-slate-100 rounded-2xl p-8 shadow-card hover:shadow-card-hover hover:scale-[1.03] transition duration-300 group hover:border-brand-green flex flex-col h-full">
				<div class="bg-brand-green text-brand-light text-xs font-bold uppercase px-4 py-1.5 rounded-full inline-block mb-5 shadow-sm self-start">Individual Round</div>
				<h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-brand-green_dark transition">Sample Algebra Round</h3>
				<p class="text-slate-700 text-base mb-8 line-clamp-3 font-light">A 45-minute individual test consisting of 10 questions of increasing difficulty focusing on algebra.</p>
				<a href="/imt-website/pdfs/IMT_Algebra_Sample.pdf" download class="w-full text-center bg-slate-900 text-white font-semibold py-3 rounded-lg hover:bg-slate-700 transition group-hover:scale-105 transform mt-auto block">
                    Download PDF Packet
                </a>
			</div>

            <div class="bg-white border-2 border-slate-100 rounded-2xl p-8 shadow-card hover:shadow-card-hover hover:scale-[1.03] transition duration-300 group hover:border-brand-green flex flex-col h-full">
				<div class="bg-brand-green text-brand-light text-xs font-bold uppercase px-4 py-1.5 rounded-full inline-block mb-5 shadow-sm self-start">Individual Round</div>
				<h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-brand-green_dark transition">Sample Geometry Round</h3>
				<p class="text-slate-700 text-base mb-8 line-clamp-3 font-light">A 45-minute individual test consisting of 10 questions of increasing difficulty focusing on geometry</p>
				<a href="/imt-website/pdfs/IMT_Geometry_Sample.pdf" download class="w-full text-center bg-slate-900 text-white font-semibold py-3 rounded-lg hover:bg-slate-700 transition group-hover:scale-105 transform mt-auto block">
                    Download PDF Packet
                </a>
			</div>

            <div class="bg-white border-2 border-slate-100 rounded-2xl p-8 shadow-card hover:shadow-card-hover hover:scale-[1.03] transition duration-300 group hover:border-brand-green flex flex-col h-full">
				<div class="bg-brand-green text-brand-light text-xs font-bold uppercase px-4 py-1.5 rounded-full inline-block mb-5 shadow-sm self-start">Individual Round</div>
				<h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-brand-green_dark transition">Sample Number Theory Round</h3>
				<p class="text-slate-700 text-base mb-8 line-clamp-3 font-light">A 45-minute individual test consisting of 10 questions of increasing difficulty focusing on number theory.</p>
				<a href="/imt-website/pdfs/IMT_Number_Theory_Sample.pdf" download class="w-full text-center bg-slate-900 text-white font-semibold py-3 rounded-lg hover:bg-slate-700 transition group-hover:scale-105 transform mt-auto block">
                    Download PDF Packet
                </a>
                </div>

            <div class="bg-white border-2 border-slate-100 rounded-2xl p-8 shadow-card hover:shadow-card-hover hover:scale-[1.03] transition duration-300 group hover:border-brand-green flex flex-col h-full">
				<div class="bg-brand-green text-brand-light text-xs font-bold uppercase px-4 py-1.5 rounded-full inline-block mb-5 shadow-sm self-start">Individual Round</div>
				<h3 class="text-2xl font-bold text-slate-950 mb-3 group-hover:text-brand-green_dark transition">Sample Combinatorics Round</h3>
				<p class="text-slate-700 text-base mb-8 line-clamp-3 font-light">A 45-minute individual test consisting of 10 questions of increasing difficulty focusing on combinatorics.</p>
				<button class="w-full bg-slate-900 text-white font-semibold py-3 rounded-lg hover:bg-slate-700 transition group-hover:scale-105 transform mt-auto">Coming Soon</button>
			</div>
		</div>
	</div>
</Layout>